{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run start)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run test)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:watch)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma migrate dev *)",
      "Bash(npx prisma migrate deploy)",
      "Bash(npx prisma migrate reset)",
      "Bash(npx prisma db seed)",
      "Bash(npx prisma studio)",
      "Bash(npx prisma validate)",
      "Bash(npx prisma format)",
      "Bash(npx prisma db pull)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npx *)",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./prisma/**)",
      "Edit(./public/**)",
      "Edit(./tests/**)",
      "Edit(./__tests__/**)",
      "Edit(./next.config.ts)",
      "Edit(./tailwind.config.ts)",
      "Edit(./tsconfig.json)",
      "Edit(./jest.config.ts)",
      "Edit(./package.json)",
      "Edit(./.eslintrc.*)",
      "Edit(./.prettierrc.*)",
      "Edit(./CLAUDE.md)",
      "Write(./src/**)",
      "Write(./prisma/**)",
      "Write(./public/**)",
      "Write(./tests/**)",
      "Write(./__tests__/**)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(npm uninstall *)",
      "Bash(npx prisma migrate reset)",
      "Bash(rm *)",
      "Bash(rmdir *)"
    ],

    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./.env.local)",
      "Edit(./.env.production)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./.env.local)",
      "Write(./.env.production)"
    ],

    "defaultMode": "default"
  },

  "includeCoAuthoredBy": true,
  "includeGitInstructions": true,
  "cleanupPeriodDays": 30,
  "respectGitignore": true
}
